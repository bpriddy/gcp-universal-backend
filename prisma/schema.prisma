datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

// ── Auth identity layer ────────────────────────────────────────────────────
// Anyone who authenticates with the platform via Google OAuth.
// May be a client, vendor, partner, external collaborator, or staff member.
// Does NOT represent org relationships — that is the Staff table.

model User {
  id          String   @id @default(uuid()) @db.Uuid
  email       String   @unique
  googleSub   String?  @unique @map("google_sub")
  displayName String?  @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  role        String   @default("viewer")
  isAdmin     Boolean  @default(false) @map("is_admin")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  permissions       UserAppPermission[]
  refreshTokens     RefreshToken[]
  grantedPerms      UserAppPermission[] @relation("GrantedByUser")
  externalIds       UserExternalId[]
  staffProfile      Staff?
  accessGrants      AccessGrant[]
  accessRequests    AccessRequest[]
  appAccessRequests AppAccessRequest[]
  oauthAuthCodes    OAuthAuthCode[]

  @@map("users")
}

// ── Org identity layer ─────────────────────────────────────────────────────
// Employees — current and former — of the agency.
// This is the source of truth for people in all org relationships:
//   campaigns.created_by, account_changes.changed_by, audit_log.actor_id
//   and any value_uuid in account_changes / campaign_changes that
//   references a person (convention: property name ends in _staff_id).
//
// user_id is nullable — not all staff have platform access.
// A staff record must never be hard-deleted; use status = 'former'.

model Office {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique
  syncCity  String?   @unique @map("sync_city")
  isActive  Boolean   @default(true) @map("is_active")
  startedAt DateTime? @map("started_at") @db.Date
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  staff   Staff[]
  changes OfficeChange[]

  @@map("offices")
}

model OfficeChange {
  id                String    @id @default(uuid()) @db.Uuid
  officeId          String    @map("office_id") @db.Uuid
  property          String
  previousValueText String?   @map("previous_value_text")
  previousValueDate DateTime? @map("previous_value_date") @db.Date
  valueText         String?   @map("value_text")
  valueDate         DateTime? @map("value_date") @db.Date
  changedBy         String?   @map("changed_by") @db.Uuid
  changedAt         DateTime  @default(now()) @map("changed_at") @db.Timestamptz

  office         Office @relation(fields: [officeId], references: [id], onDelete: Cascade)
  changedByStaff Staff? @relation("OfficeChangedByStaff", fields: [changedBy], references: [id])

  @@index([officeId, property, changedAt(sort: Desc)])
  @@map("office_changes")
}

model Team {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  startedAt   DateTime? @map("started_at") @db.Date
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  members TeamMember[]
  changes TeamChange[]

  @@map("teams")
}

model TeamChange {
  id                String    @id @default(uuid()) @db.Uuid
  teamId            String    @map("team_id") @db.Uuid
  property          String
  previousValueText String?   @map("previous_value_text")
  previousValueDate DateTime? @map("previous_value_date") @db.Date
  valueText         String?   @map("value_text")
  valueDate         DateTime? @map("value_date") @db.Date
  changedBy         String?   @map("changed_by") @db.Uuid
  changedAt         DateTime  @default(now()) @map("changed_at") @db.Timestamptz

  team           Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  changedByStaff Staff? @relation("TeamChangedByStaff", fields: [changedBy], references: [id])

  @@index([teamId, property, changedAt(sort: Desc)])
  @@map("team_changes")
}

model TeamMember {
  id      String   @id @default(uuid()) @db.Uuid
  teamId  String   @map("team_id") @db.Uuid
  staffId String   @map("staff_id") @db.Uuid
  addedAt DateTime @default(now()) @map("added_at") @db.Timestamptz

  team  Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([teamId, staffId])
  @@index([staffId])
  @@map("team_members")
}

model Staff {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String?   @unique @map("user_id") @db.Uuid
  officeId   String?   @map("office_id") @db.Uuid
  fullName   String    @map("full_name")
  email      String    @unique
  title      String?
  department String?
  status     String    @default("active")
  startedAt  DateTime  @map("started_at") @db.Date
  endedAt    DateTime? @map("ended_at") @db.Date
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user                   User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  office                 Office?               @relation(fields: [officeId], references: [id], onDelete: SetNull)
  teamMemberships        TeamMember[]
  externalIds            StaffExternalId[]
  changes                StaffChange[]
  accountChanges         AccountChange[]       @relation("AccountChangedByStaff")
  campaignsCreated       Campaign[]            @relation("CampaignCreatedByStaff")
  campaignChanges        CampaignChange[]      @relation("CampaignChangedByStaff")
  officeChanges          OfficeChange[]        @relation("OfficeChangedByStaff")
  teamChanges            TeamChange[]          @relation("TeamChangedByStaff")
  auditActions           AuditLog[]            @relation("AuditLogActorStaff")
  grantsGiven            AccessGrant[]         @relation("AccessGrantGrantedByStaff")
  grantsRevoked          AccessGrant[]         @relation("AccessGrantRevokedByStaff")
  reviewedRequests       AccessRequest[]       @relation("AccessRequestReviewedByStaff")
  reviewedAppRequests    AppAccessRequest[]    @relation("AppAccessRequestReviewedByStaff")
  metadata               StaffMetadata[]
  ownedAccounts          Account[]             @relation("AccountOwnerStaff")
  accountsAsExec         Account[]             @relation("AccountExecStaff")
  driveProposalReviews   DriveChangeProposal[] @relation("DriveProposalReviewerStaff")
  driveProposalDecisions DriveChangeProposal[] @relation("DriveProposalDecidedByStaff")
  promptPresetEdits      PromptPreset[]        @relation("PromptPresetUpdatedByStaff")

  @@index([userId])
  @@index([officeId])
  @@index([status])
  @@map("staff")
}

// Append-only change log for staff — same pattern as account_changes / office_changes.
// source: 'google_directory_sync' | 'admin' | 'csv_import' (how the change arrived)
model StaffChange {
  id                String    @id @default(uuid()) @db.Uuid
  staffId           String    @map("staff_id") @db.Uuid
  property          String
  previousValueText String?   @map("previous_value_text")
  previousValueUuid String?   @map("previous_value_uuid") @db.Uuid
  previousValueDate DateTime? @map("previous_value_date") @db.Date
  valueText         String?   @map("value_text")
  valueUuid         String?   @map("value_uuid") @db.Uuid
  valueDate         DateTime? @map("value_date") @db.Date
  valueIsPii        Boolean   @default(false) @map("value_is_pii")
  source            String    @default("admin")
  changedAt         DateTime  @default(now()) @map("changed_at") @db.Timestamptz

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, property, changedAt(sort: Desc)])
  @@map("staff_changes")
}

model StaffExternalId {
  id         String   @id @default(uuid()) @db.Uuid
  staffId    String   @map("staff_id") @db.Uuid
  system     String
  externalId String   @map("external_id")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([system, externalId])
  @@index([staffId])
  @@map("staff_external_ids")
}

// ── Accounts ───────────────────────────────────────────────────────────────

model Account {
  id                  String    @id @default(uuid()) @db.Uuid
  name                String
  parentId            String?   @map("parent_id") @db.Uuid
  ownerStaffId        String?   @map("owner_staff_id") @db.Uuid
  // Business fields ("write both": state on row, history in account_changes).
  // Drive sync proposals target these; allowlist lives in drive.schema.ts.
  status              String?
  accountExecStaffId  String?   @map("account_exec_staff_id") @db.Uuid
  industry            String?
  primaryContactName  String?   @map("primary_contact_name")
  primaryContactEmail String?   @map("primary_contact_email")
  notes               String?
  // Drive anchoring
  driveFolderId       String?   @map("drive_folder_id")
  driveFolderUrl      String?   @map("drive_folder_url")
  driveFolderPath     String?   @map("drive_folder_path")
  driveLastScannedAt  DateTime? @map("drive_last_scanned_at") @db.Timestamptz
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  parent             Account?              @relation("AccountHierarchy", fields: [parentId], references: [id])
  children           Account[]             @relation("AccountHierarchy")
  owner              Staff?                @relation("AccountOwnerStaff", fields: [ownerStaffId], references: [id], onDelete: SetNull)
  accountExec        Staff?                @relation("AccountExecStaff", fields: [accountExecStaffId], references: [id], onDelete: SetNull)
  changes            AccountChange[]
  campaigns          Campaign[]
  driveFileSnapshots DriveFileSnapshot[]
  driveScanLogs      DriveScanLog[]
  driveProposals     DriveChangeProposal[]

  @@index([ownerStaffId])
  @@index([accountExecStaffId])
  @@index([status])
  @@index([driveFolderId])
  @@map("accounts")
}

// Append-only log of account property changes.
// Current state = latest changedAt per property.
// When value_uuid references a staff member, the property name
// should end in _staff_id (e.g. account_exec_staff_id).
model AccountChange {
  id                String    @id @default(uuid()) @db.Uuid
  accountId         String    @map("account_id") @db.Uuid
  property          String
  previousValueText String?   @map("previous_value_text")
  previousValueUuid String?   @map("previous_value_uuid") @db.Uuid
  previousValueDate DateTime? @map("previous_value_date") @db.Date
  valueText         String?   @map("value_text")
  valueUuid         String?   @map("value_uuid") @db.Uuid
  valueDate         DateTime? @map("value_date") @db.Date
  changedBy         String    @map("changed_by") @db.Uuid
  changedAt         DateTime  @default(now()) @map("changed_at") @db.Timestamptz

  account        Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  changedByStaff Staff   @relation("AccountChangedByStaff", fields: [changedBy], references: [id])

  @@index([accountId, property, changedAt(sort: Desc)])
  @@map("account_changes")
}

// ── Campaigns ──────────────────────────────────────────────────────────────

model Campaign {
  id                 String    @id @default(uuid()) @db.Uuid
  accountId          String    @map("account_id") @db.Uuid
  name               String
  status             String    @default("pitch")
  budget             Decimal?  @db.Decimal(15, 2)
  assetsUrl          String?   @map("assets_url")
  awardedAt          DateTime? @map("awarded_at") @db.Date
  liveAt             DateTime? @map("live_at") @db.Date
  endsAt             DateTime? @map("ends_at") @db.Date
  driveFolderId      String?   @map("drive_folder_id")
  driveFolderUrl     String?   @map("drive_folder_url")
  driveFolderPath    String?   @map("drive_folder_path")
  driveLastScannedAt DateTime? @map("drive_last_scanned_at") @db.Timestamptz
  createdBy          String    @map("created_by") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  account            Account               @relation(fields: [accountId], references: [id])
  createdByStaff     Staff                 @relation("CampaignCreatedByStaff", fields: [createdBy], references: [id])
  changes            CampaignChange[]
  driveFileSnapshots DriveFileSnapshot[]
  driveScanLogs      DriveScanLog[]
  driveProposals     DriveChangeProposal[]

  @@index([accountId])
  @@index([status])
  @@index([driveFolderId])
  @@map("campaigns")
}

// Append-only log of campaign property changes.
// Same conventions as AccountChange.
model CampaignChange {
  id                String    @id @default(uuid()) @db.Uuid
  campaignId        String    @map("campaign_id") @db.Uuid
  property          String
  previousValueText String?   @map("previous_value_text")
  previousValueUuid String?   @map("previous_value_uuid") @db.Uuid
  previousValueDate DateTime? @map("previous_value_date") @db.Date
  valueText         String?   @map("value_text")
  valueUuid         String?   @map("value_uuid") @db.Uuid
  valueDate         DateTime? @map("value_date") @db.Date
  changedBy         String    @map("changed_by") @db.Uuid
  changedAt         DateTime  @default(now()) @map("changed_at") @db.Timestamptz

  campaign       Campaign @relation(fields: [campaignId], references: [id])
  changedByStaff Staff    @relation("CampaignChangedByStaff", fields: [changedBy], references: [id])

  @@index([campaignId, property, changedAt(sort: Desc)])
  @@map("campaign_changes")
}

// ── Audit log ──────────────────────────────────────────────────────────────
// Append-only. Immutable at the DB level via trigger.
// actor_id references staff — platform actions are always attributed
// to an org identity, not a raw auth credential.

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id") @db.Uuid
  actorId    String   @map("actor_id") @db.Uuid
  before     Json?
  after      Json?
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  actor Staff @relation("AuditLogActorStaff", fields: [actorId], references: [id])

  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@map("audit_log")
}

// ── Access control ─────────────────────────────────────────────────────────
// Fully explicit per-resource grants. Every user needs a row per resource.
// No implicit inheritance. grantAccountAccess() creates all rows in one call.
// Soft revoke only — never hard-delete, preserve audit trail.
// is_admin on users bypasses all checks — superuser escape hatch.
//
// NOTE: the partial unique index (WHERE revoked_at IS NULL) cannot be expressed
// in Prisma schema — it lives only in the migration SQL. Prisma's @@unique
// without a WHERE clause would incorrectly block re-granting after revocation.

model AccessGrant {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  resourceType String    @map("resource_type")
  resourceId   String    @map("resource_id") @db.Uuid
  role         String    @default("viewer")
  grantedBy    String    @map("granted_by") @db.Uuid
  grantedAt    DateTime  @default(now()) @map("granted_at") @db.Timestamptz
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz
  revokedBy    String?   @map("revoked_by") @db.Uuid

  user           User   @relation(fields: [userId], references: [id], onDelete: Restrict)
  grantedByStaff Staff  @relation("AccessGrantGrantedByStaff", fields: [grantedBy], references: [id], onDelete: Restrict)
  revokedByStaff Staff? @relation("AccessGrantRevokedByStaff", fields: [revokedBy], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([userId, resourceType, resourceId])
  @@index([resourceType, resourceId])
  @@index([grantedBy])
  @@map("access_grants")
}

// ── Access requests ────────────────────────────────────────────────────────
// Users submit a request when they believe they should have access to a
// resource or functional capability they can't currently see.
// Admins review the queue in gub-admin and approve (which creates a grant)
// or deny (with an optional note).

model AccessRequest {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  // Same domain as AccessGrant.resourceType: account | campaign | office | team
  // | func:temporal | func:export | func:admin_ui | staff:all | staff:current | etc.
  resourceType      String    @map("resource_type")
  // Specific resource UUID — null for functional / scope grants (func:*, staff:*)
  resourceId        String?   @map("resource_id") @db.Uuid
  // Role or capability level being requested (viewer / contributor / rolling_1yr / etc.)
  requestedRole     String    @map("requested_role")
  // Optional free-text from the requester explaining why they need access
  reason            String?
  // pending | approved | denied
  status            String    @default("pending")
  reviewedByStaffId String?   @map("reviewed_by_staff_id") @db.Uuid
  reviewedAt        DateTime? @map("reviewed_at") @db.Timestamptz
  // Optional note from the reviewer (denial reason, approval conditions, etc.)
  reviewNote        String?   @map("review_note")
  // Populated on approval — points to the grant that was created
  grantId           String?   @map("grant_id") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user            User   @relation(fields: [userId], references: [id], onDelete: Restrict)
  reviewedByStaff Staff? @relation("AccessRequestReviewedByStaff", fields: [reviewedByStaffId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([resourceType, resourceId])
  @@map("access_requests")
}

// ── Auth support tables ────────────────────────────────────────────────────

model UserExternalId {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  system     String
  externalId String   @map("external_id")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([system, externalId])
  @@index([userId])
  @@map("user_external_ids")
}

model App {
  id           String   @id @default(uuid()) @db.Uuid
  appId        String   @unique @map("app_id")
  name         String
  description  String?
  autoAccess   Boolean  @default(false) @map("auto_access")
  dbIdentifier String?  @map("db_identifier")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  permissions    UserAppPermission[]
  accessRequests AppAccessRequest[]

  @@map("apps")
}

model UserAppPermission {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  appId       String   @map("app_id")
  role        String   @default("viewer")
  grantedAt   DateTime @default(now()) @map("granted_at") @db.Timestamptz
  grantedById String?  @map("granted_by") @db.Uuid

  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  grantedBy User? @relation("GrantedByUser", fields: [grantedById], references: [id])
  app       App   @relation(fields: [appId], references: [appId], onDelete: Cascade)

  @@unique([userId, appId])
  @@map("user_app_permissions")
}

model AppAccessRequest {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  appId             String    @map("app_id")
  reason            String?
  status            String    @default("pending")
  reviewedByStaffId String?   @map("reviewed_by_staff_id") @db.Uuid
  reviewedAt        DateTime? @map("reviewed_at") @db.Timestamptz
  reviewNote        String?   @map("review_note")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user            User   @relation(fields: [userId], references: [id], onDelete: Restrict)
  app             App    @relation(fields: [appId], references: [appId], onDelete: Cascade)
  reviewedByStaff Staff? @relation("AppAccessRequestReviewedByStaff", fields: [reviewedByStaffId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([appId])
  @@index([status])
  @@map("app_access_requests")
}

model RefreshToken {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  tokenHash    String    @unique @map("token_hash")
  family       String    @db.Uuid
  issuedAt     DateTime  @default(now()) @map("issued_at") @db.Timestamptz
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz
  replacedById String?   @map("replaced_by") @db.Uuid
  ipAddress    String?   @map("ip_address")
  userAgent    String?   @map("user_agent")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([family])
  @@map("refresh_tokens")
}

// ── OAuth Broker ───────────────────────────────────────────────────────────
// Supports server-side OAuth flow for headless clients (e.g. Agentspace MCP).
// GUB acts as a thin Authorization Server, proxying Google identity while
// issuing its own JWTs.  Client-side flows (/auth/google/exchange) are
// unaffected and do not use these tables.

model OAuthClient {
  id               String   @id @default(uuid()) @db.Uuid
  clientId         String   @unique @map("client_id")
  clientSecretHash String   @map("client_secret_hash")
  name             String
  redirectUris     String[] @map("redirect_uris")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  pendingAuths OAuthPendingAuth[]
  authCodes    OAuthAuthCode[]

  @@map("oauth_clients")
}

model OAuthPendingAuth {
  id          String   @id @default(uuid()) @db.Uuid
  clientId    String   @map("client_id")
  redirectUri String   @map("redirect_uri")
  clientState String?  @map("client_state")
  expiresAt   DateTime @map("expires_at") @db.Timestamptz
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  client OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)

  @@index([expiresAt])
  @@map("oauth_pending_auths")
}

model OAuthAuthCode {
  id          String    @id @default(uuid()) @db.Uuid
  codeHash    String    @unique @map("code_hash")
  clientId    String    @map("client_id")
  userId      String    @map("user_id") @db.Uuid
  redirectUri String    @map("redirect_uri")
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz
  usedAt      DateTime? @map("used_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  client OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("oauth_auth_codes")
}

model StaffMetadata {
  id         String   @id @default(uuid()) @db.Uuid
  staffId    String   @map("staff_id") @db.Uuid
  type       String
  label      String
  value      String?
  notes      String?
  metadata   Json?
  isFeatured Boolean  @default(false) @map("is_featured")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, type])
  @@index([type, label])
  @@index([type, value])
  @@map("staff_metadata")
}

// ── Sync runs ─────────────────────────────────────────────────────────────
// One row per execution of any sync engine (google_directory, workfront, etc.).
// `details` is structured JSONB for programmatic access; `summary` is a
// pre-rendered human-readable digest for the admin UI.

model DataSource {
  id           String    @id @default(uuid()) @db.Uuid
  key          String    @unique // 'google_directory' | 'workfront' | etc.
  name         String // 'Google Directory'
  description  String?   @db.Text
  isActive     Boolean   @default(true) @map("is_active")
  syncInterval String    @default("daily") @map("sync_interval") // 'hourly' | 'daily' | 'weekly' | 'manual'
  cronSchedule String?   @map("cron_schedule") // '0 6 * * *' — actual cron expression
  lastSyncAt   DateTime? @map("last_sync_at") @db.Timestamptz
  lastStatus   String?   @map("last_status") // 'success' | 'failed'
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@map("data_sources")
}

model SyncRun {
  id          String    @id @default(uuid()) @db.Uuid
  source      String // 'google_directory' | 'workfront' | 'google_drive' | etc.
  status      String    @default("running") // 'running' | 'success' | 'failed'
  startedAt   DateTime  @default(now()) @map("started_at") @db.Timestamptz
  completedAt DateTime? @map("completed_at") @db.Timestamptz
  durationMs  Int?      @map("duration_ms")

  // Counters
  totalScanned Int @default(0) @map("total_scanned")
  created      Int @default(0)
  updated      Int @default(0)
  unchanged    Int @default(0)
  skipped      Int @default(0)
  errored      Int @default(0)

  // Structured details — skips, errors, warnings, changes with previous values
  details Json?

  // Human-readable narrative summary for the admin dashboard
  summary String? @db.Text

  @@index([source, startedAt(sort: Desc)])
  @@index([status])
  @@map("sync_runs")
}

// ── Prompt presets ────────────────────────────────────────────────────────
// Editable LLM prompt templates used across modules. Lookup by key.
// `variables` is a JSON array of declared variable names.

model PromptPreset {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  description String?
  template    String   @db.Text
  variables   Json     @default("[]")
  model       String   @default("gemini-2.5-pro")
  temperature Decimal  @default(0.20) @db.Decimal(3, 2)
  isActive    Boolean  @default(true) @map("is_active")
  updatedBy   String?  @map("updated_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  updatedByStaff Staff? @relation("PromptPresetUpdatedByStaff", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@map("prompt_presets")
}

// ── Drive file snapshots ──────────────────────────────────────────────────
// Append-only per-file history. Powers delta-skip: compare Drive's modifiedTime
// to the latest scanned_at row for this file_id.

model DriveFileSnapshot {
  id           String    @id @default(uuid()) @db.Uuid
  syncRunId    String?   @map("sync_run_id") @db.Uuid
  fileId       String    @map("file_id")
  accountId    String?   @map("account_id") @db.Uuid
  campaignId   String?   @map("campaign_id") @db.Uuid
  name         String
  mimeType     String?   @map("mime_type")
  path         String?
  modifiedTime DateTime? @map("modified_time") @db.Timestamptz
  modifiedBy   String?   @map("modified_by")
  sizeBytes    BigInt?   @map("size_bytes")
  contentHash  String?   @map("content_hash")
  wasExtracted Boolean   @default(false) @map("was_extracted")
  skipReason   String?   @map("skip_reason")
  scannedAt    DateTime  @default(now()) @map("scanned_at") @db.Timestamptz

  account  Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([fileId, scannedAt(sort: Desc)])
  @@index([accountId])
  @@index([campaignId])
  @@index([syncRunId])
  @@map("drive_file_snapshots")
}

// ── Drive scan logs ───────────────────────────────────────────────────────
// Uncategorized-but-interesting info and operational warnings sink.
// Mirrors the directory-sync-logs UX in gub-admin.

model DriveScanLog {
  id         String   @id @default(uuid()) @db.Uuid
  syncRunId  String?  @map("sync_run_id") @db.Uuid
  accountId  String?  @map("account_id") @db.Uuid
  campaignId String?  @map("campaign_id") @db.Uuid
  fileId     String?  @map("file_id")
  level      String // info | note | warn | error
  category   String // uncategorized_insight | ambiguous | skipped_* | *_error | diagnostic
  message    String
  payload    Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  account  Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([syncRunId])
  @@index([accountId, createdAt(sort: Desc)])
  @@index([campaignId, createdAt(sort: Desc)])
  @@index([level])
  @@map("drive_scan_logs")
}

// ── Drive change proposals ────────────────────────────────────────────────
// Structured proposals emitted by the distillation step. Reviewed by the
// account owner via magic link. On approval, a row is written to
// account_changes / campaign_changes with the reviewer's staff_id.

model DriveChangeProposal {
  id                  String    @id @default(uuid()) @db.Uuid
  syncRunId           String?   @map("sync_run_id") @db.Uuid
  // kind='field_change' edits an existing row; kind='new_entity' proposes
  // creating a new account/campaign. new_entity rows share a proposal_group_id
  // and carry source_drive_folder_id so approval can link folder→new row.
  kind                String    @default("field_change")
  proposalGroupId     String?   @map("proposal_group_id") @db.Uuid
  sourceDriveFolderId String?   @map("source_drive_folder_id")
  entityType          String    @map("entity_type") // 'account' | 'campaign'
  accountId           String?   @map("account_id") @db.Uuid
  campaignId          String?   @map("campaign_id") @db.Uuid
  property            String
  currentValue        Json?     @map("current_value")
  proposedValue       Json?     @map("proposed_value")
  reasoning           String?
  sourceFileIds       String[]  @map("source_file_ids")
  confidence          Decimal?  @db.Decimal(3, 2)
  state               String    @default("pending") // pending | approved | rejected | applied | expired
  reviewToken         String    @unique @map("review_token")
  reviewerEmail       String?   @map("reviewer_email")
  reviewerStaffId     String?   @map("reviewer_staff_id") @db.Uuid
  expiresAt           DateTime  @map("expires_at") @db.Timestamptz
  // Null until the notify service emails the reviewer. Set once per proposal;
  // if the same reviewer also owns later proposals we'll batch those into
  // their own email when they accumulate.
  notifiedAt          DateTime? @map("notified_at") @db.Timestamptz
  decidedAt           DateTime? @map("decided_at") @db.Timestamptz
  decidedBy           String?   @map("decided_by") @db.Uuid
  appliedChangeId     String?   @map("applied_change_id") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz

  account        Account?  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  campaign       Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  reviewerStaff  Staff?    @relation("DriveProposalReviewerStaff", fields: [reviewerStaffId], references: [id], onDelete: SetNull)
  decidedByStaff Staff?    @relation("DriveProposalDecidedByStaff", fields: [decidedBy], references: [id], onDelete: SetNull)

  @@index([state])
  @@index([accountId, state])
  @@index([campaignId, state])
  @@index([syncRunId])
  @@index([reviewerStaffId])
  @@index([expiresAt])
  @@index([proposalGroupId])
  @@index([sourceDriveFolderId])
  @@index([kind, state])
  @@index([reviewerStaffId, state, notifiedAt])
  @@map("drive_change_proposals")
}
