# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ── Database ─────────────────────────────────────────────────────────────────
# Runtime connection — gub_app role (DML only, no DDL). Used by the API at runtime.
# Production: postgresql://gub_app:<password>@<host>:5432/gub?sslmode=require
DATABASE_URL=postgresql://gub_app:change_me_app@localhost:5432/gub_dev

# Migration connection — gub_migrator role (DDL). Used only by db:migrate scripts.
# Production: postgresql://gub_migrator:<password>@<host>:5432/gub?sslmode=require
DATABASE_MIGRATOR_URL=postgresql://gub_migrator:change_me_migrator@localhost:5432/gub_dev

# ── Application Database Connection Pool Registry ────────────────────────────
# JSON map of db_identifier → PostgreSQL connection string
# Each value is the DATABASE_URL for the target application's database
APP_DB_CONNECTIONS={"analytics":"postgresql://user:pass@host/analytics_db","crm":"postgresql://user:pass@host/crm_db"}

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Comma-separated list of additional OAuth client IDs GUB will accept on
# /auth/google (GOOGLE_CLIENT_ID is always implicitly included). Each client
# app you onboard should have its own OAuth client; add its ID here.
GOOGLE_ALLOWED_AUDIENCES=other-app.apps.googleusercontent.com,yet-another.apps.googleusercontent.com

# ── OAuth Broker (server-side Code flow, e.g. Agentspace / ADK agent) ────────
# Client secret for the GOOGLE_CLIENT_ID above — ONLY needed when the backend
# performs the OAuth 2.0 authorization-code exchange. Frontend apps that only
# do Google One Tap do NOT need this.
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxx
# The /auth/google/broker/callback URL GUB is registered as in the OAuth client.
# GOOGLE_BROKER_REDIRECT_URI=https://gub.example.com/auth/google/broker/callback

# ── OAuth Broker test UI (POST /dev/broker-test/exchange) ────────────────────
# Only used by the in-repo broker test page. Never mounted in production.
# BROKER_TEST_CLIENT_ID=<registered OAuth client id for the test page>
# BROKER_TEST_CLIENT_SECRET=<matching secret>
# BROKER_TEST_REDIRECT_URI=https://gub.example.com/dev/broker-test/callback

# ── JWT RS256 Keys ────────────────────────────────────────────────────────────
# Option A: File paths (recommended for local dev — run npm run keys:generate)
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
# Option B: Base64-encoded PEM strings (recommended for GCP Cloud Run / Secret Manager)
# JWT_PRIVATE_KEY_B64=<base64-encoded-PKCS8-RSA-private-key>
# JWT_PUBLIC_KEY_B64=<base64-encoded-SPKI-RSA-public-key>

JWT_KEY_ID=key-v1
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=2592000
JWT_ISSUER=https://auth.yourcompany.com
JWT_AUDIENCE=https://api.yourcompany.com

# ── CORS ─────────────────────────────────────────────────────────────────────
# DEPRECATED — the allow-list now lives in the cors_allowed_origins DB
# table, manageable via the gub-admin Settings UI at runtime. See
# migration 20260430010000_cors_allowed_origins for the seed and
# README "CORS allow-list — dev/staging tooling" for the architecture.
# This env var is no longer read by the running app.
# CORS_ALLOWED_ORIGINS=  (unused)

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ── GCP ──────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-project-id

# ── Sibling service URLs ─────────────────────────────────────────────────────
# URLs of the other GUB-ecosystem services. GUB uses them for links in
# outbound emails and (for workspace pass-through) for the X-Workspace-Token
# flow. Falls back to admin URL if review is unset.
GUB_ADMIN_BASE_URL=http://localhost:3001
GUB_REVIEW_BASE_URL=http://localhost:3003

# ── Self-call base URL ──────────────────────────────────────────────────────
# The Drive sync chunker self-POSTs to /run-full-sync/continue when a chunk's
# wall-clock budget trips. This is the base URL it calls. Falls back to
# JWT_ISSUER (which today is the same value in deployed environments).
# In local dev: leave unset; chunking is unlikely to trip on dev folders.
# SELF_BASE_URL=http://localhost:3000

# ── Google Workspace Directory sync ──────────────────────────────────────────
# Service account with domain-wide delegation, used to read the directory.
# One of key path or base64 required.
# GOOGLE_DIRECTORY_SA_KEY_PATH=./secrets/directory-sa.json
# GOOGLE_DIRECTORY_SA_KEY_B64=<base64-encoded-service-account-json>
# Domain user to impersonate (any active member works — directory is readable
# by all members).
# GOOGLE_DIRECTORY_IMPERSONATE_EMAIL=you@yourcompany.com

# ── Workfront ────────────────────────────────────────────────────────────────
# WORKFRONT_BASE_URL=https://yourcompany.my.workfront.com
# WORKFRONT_API_TOKEN=<workfront-api-token>

# ── Mail ─────────────────────────────────────────────────────────────────────
# 'console' is a dry-run driver that logs the message — safe default for dev.
# Flip to 'mailgun' in production. Mailgun driver needs MAILGUN_API_KEY +
# MAILGUN_DOMAIN + MAIL_FROM_ADDRESS; if any are missing it falls back to the
# console driver with a warning.
MAIL_DRIVER=console
# MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MAILGUN_DOMAIN=mg.example.com
# MAILGUN_REGION=us                     # 'us' (default) or 'eu'
# MAIL_FROM_ADDRESS=noreply@example.com
# MAIL_FROM_NAME=GUB

# ── Google Drive sync ────────────────────────────────────────────────────────
# Two auth paths; see drive.client.ts for full rationale.
#
# Path A (legacy, key-file). Drive folders shared with the SA's email
# directly. Falls back to GOOGLE_DIRECTORY_SA_KEY_* if Drive-specific vars
# aren't set.
# GOOGLE_DRIVE_SA_KEY_PATH=./keys/drive-sa.json
# GOOGLE_DRIVE_SA_KEY_B64=<base64-encoded-service-account-json>
#
# Path B (preferred, STS impersonation chain — production posture). When
# GOOGLE_DRIVE_TARGET_SA is set, the Drive client uses ADC to impersonate
# this SA via iamcredentials.signJwt, then exchanges the signed JWT for an
# access token with the bot user as the DWD subject. The Workspace admin
# grants DWD (scope drive.readonly) to THIS SA only — never to the
# runtime SA. Runtime SA needs roles/iam.serviceAccountTokenCreator on
# this SA.
# GOOGLE_DRIVE_TARGET_SA=gdrive-scanner@your-project.iam.gserviceaccount.com
#
# The bot user (proxy user) the Drive SA impersonates via DWD. This is
# the @yourdomain Workspace user shared on each restricted Drive. Required
# for both paths when DWD is in use; mandatory for Path B.
# GOOGLE_DRIVE_IMPERSONATE_EMAIL=bot@yourdomain.com
# Shared-drive root folder id — required for new-entity discovery / full sync.
# DRIVE_ROOT_FOLDER_ID=0Axxxxxxxxxxxxxxxxx
DRIVE_DELAY_BETWEEN_ACCOUNTS_MS=5000
DRIVE_DELAY_BETWEEN_CAMPAIGNS_MS=2000
DRIVE_DELAY_BETWEEN_FILES_MS=500
DRIVE_MAX_FILE_SIZE_BYTES=26214400
DRIVE_PROPOSAL_TTL_DAYS=14

# ── AI / Gemini ──────────────────────────────────────────────────────────────
# When GEMINI_API_KEY is unset, the AI module uses a mock driver that returns
# empty observations — pipelines still run end-to-end in dev.
# GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MAX_INPUT_CHARS=40000
