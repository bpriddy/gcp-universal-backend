# Terraform local state and cache.
# .terraform.lock.hcl is INTENTIONALLY committed — it pins provider versions
# across operators and CI. See terraform/README.md "Provider versions".
.terraform/
*.tfstate
*.tfstate.backup

# Crash logs
crash.log
crash.*.log

# Override files (local developer customization)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# tfvars containing secrets (env files are safe — no secrets)
# *.auto.tfvars
