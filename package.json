{
  "name": "gcp-universal-backend",
  "version": "1.0.0",
  "description": "Universal GCP backend auth gateway — Google OAuth to JWT with multi-database routing",
  "main": "dist/server.js",
  "exports": {
    ".": "./dist/server.js",
    "./sdk/frontend": "./sdk/frontend/index.tsx",
    "./sdk/backend": "./sdk/backend/index.ts"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node -r dotenv/config src/server.ts",
    "db:generate": "prisma generate",
    "db:migrate": "DATABASE_URL=$DATABASE_MIGRATOR_URL prisma migrate deploy",
    "db:migrate:dev": "DATABASE_URL=$DATABASE_MIGRATOR_URL prisma migrate dev",
    "db:roles": "psql $DATABASE_MIGRATOR_URL -f scripts/setup-db-roles.sql",
    "db:cleanup": "node -r dotenv/config dist/scripts/cleanup.js",
    "db:studio": "prisma studio",
    "keys:generate": "bash scripts/generate-keys.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^5.10.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "google-auth-library": "^9.6.3",
    "helmet": "^7.1.0",
    "jose": "^5.2.3",
    "pg": "^8.11.3",
    "pino": "^8.19.0",
    "pino-http": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.25",
    "@types/pg": "^8.11.2",
    "prisma": "^5.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.2",
    "vitest": "^1.3.1"
  }
}
